{
  "projectId": "b1ca2887-306e-4aba-9a5c-7f7f8a1f10d4",
  "pkg": "portfolio",
  "globalName": "Portfolio",
  "shape": "package",
  "entry": "./dist/index.js",
  "srcDir": "components",
  "cssEntry": "./.design-sync/.cache/chunks/compiled.css",
  "buildCmd": "bun run build && mkdir -p .design-sync/.cache/chunks .design-sync/.cache/media && cp $(ls -S .next/static/chunks/*.css | head -1) .design-sync/.cache/chunks/compiled.css && cp .next/static/media/* .design-sync/.cache/media/",
  "extraEntries": ["./.design-sync/process-shim.mjs", "./.design-sync/messages-ref.mjs", "next-intl", "next-themes"],
  "tsconfig": "./tsconfig.json",
  "provider": {
    "component": "NextIntlClientProvider",
    "props": { "locale": "en", "messages": { "$ref": "enMessages" } },
    "inner": { "component": "ThemeProvider", "props": { "attribute": "class" } }
  },
  "overrides": {
    "ProjectPhotoLightbox": { "cardMode": "single", "viewport": "480x360" },
    "MobileMenu": { "cardMode": "single", "viewport": "375x220" }
  },
  "readmeHeader": ".design-sync/conventions.md"
}
